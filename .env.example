# ═══════════════════════════════════════════════════════════════════════════
# freela-mailer — required envs
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Database (mailer-owned; do NOT share with freela)
DATABASE_URL=postgresql://mailer:mailer_password@db:5432/mailer?schema=public
POSTGRES_DB=mailer
POSTGRES_USER=mailer
POSTGRES_PASSWORD=change_me

# Redis (mailer-owned; do NOT share with freela)
REDIS_URL=redis://redis:6379

# Forever-host URL baked into outgoing tracking pixels and unsubscribe links.
# MUST stay stable across deploys — historical emails point here permanently.
# In prod, set to the host that forever-serves those URLs (typically
# https://freela.ge because recipients have that domain in old inboxes).
MAILER_PUBLIC_URL=https://freela.ge

# Per-product Redis rate-limit namespace (prevents key collisions).
RATE_LIMIT_KEY_PREFIX=mailer:

# Respect X-Forwarded-* headers only behind a trusted reverse proxy.
TRUST_PROXY_HEADERS=true
RATE_LIMIT_STRICT=true

# ── Secrets ─────────────────────────────────────────────────────────────────
# Desktop JWT signing keys (mailer-only — never shared with freela)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# HMAC signer for unsubscribe-link tokens — must match the value used in
# freela during the cutover window so historical emails keep verifying.
UNSUBSCRIBE_TOKEN_SECRET=

# Internal API secret used by /api/unsubscribed cross-tenant sync.
INTERNAL_API_SECRET=

# AES-256-GCM key encrypting SMTP credentials (DesktopSmtp* tables).
# Generate once, keep stable: `openssl rand -hex 32`.
SMTP_CONFIG_SECRET=

# Optional: comma-separated read-only fallbacks used during key rotation.
# SMTP_CONFIG_SECRET_FALLBACK=

# Set to "true" only during the one-off legacy → primary re-encrypt window.
# LEGACY_SMTP_CRYPTO_FALLBACK=false

# ── Worker ──────────────────────────────────────────────────────────────────
ENABLE_IN_PROCESS_CAMPAIGN_WORKER=false
WORKER_HEALTH_PORT=3001

CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_DELAY_MIN_MS=200
CAMPAIGN_DELAY_MAX_MS=1000
CAMPAIGN_BATCH_PAUSE_MS=5000
CAMPAIGN_SCHEDULER_POLL_MS=30000

CAMPAIGN_WARMUP_ENABLED=false
CAMPAIGN_WARMUP_START=10
CAMPAIGN_WARMUP_INCREMENT=10
CAMPAIGN_WARMUP_MAX=0

TRACK_OPENS=true
TRACK_CLICKS=true

# Export storage (shared volume between `app` and `worker`).
MAILER_EXPORT_DIR=/data/exports

# ── Observability (separate from freela's Sentry project) ──────────────────
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# LOG_LEVEL=info

# Health check token (optional)
# HEALTH_CHECK_TOKEN=

# ─── Path-mount (pre-subdomain launch) ───────────────────────────────────────
# Set to "/mailer" when this container is fronted under https://freela.ge/mailer
# by freela's Caddy. Leave blank/unset when serving directly on a dedicated
# subdomain (https://mailer.freela.ge). MUST be available at build time — Next.js
# inlines NEXT_PUBLIC_* into the client bundle; runtime env changes won't take
# effect. Rebuild the image when flipping this.
# NEXT_PUBLIC_MAILER_BASE_PATH=/mailer

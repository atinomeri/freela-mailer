{
  "name": "freela-mailer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "npx tsx scripts/mailer-worker.mjs",
    "migrate:smtp-crypto": "npx tsx scripts/rotate-smtp-crypto.mjs",
    "migrate:smtp-crypto:dry": "npx tsx scripts/rotate-smtp-crypto.mjs --dry",
    "prisma:generate": "prisma generate --config=./prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config=./prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config=./prisma.config.ts",
    "prisma:validate": "prisma validate --config=./prisma.config.ts",
    "prisma:studio": "prisma studio --config=./prisma.config.ts"
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not op_mini all"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/nextjs": "^10.38.0",
    "@swc/helpers": "^0.5.18",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.0",
    "clsx": "^2.1.1",
    "grapesjs": "^0.22.13",
    "grapesjs-mjml": "^1.0.8",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.36",
    "lucide-react": "^0.475.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.2",
    "nodemailer": "^7.0.13",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.10.0",
    "tailwind-merge": "^2.5.5",
    "tsx": "^4.19.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.9",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.49",
    "prisma": "^7.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}

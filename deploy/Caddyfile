# Mailer Caddyfile — deployed standalone on the mailer host to terminate TLS
# for mailer.freela.ge. See freela/deploy/Caddyfile for the complementary
# compat-proxy that forwards legacy freela.ge paths to this host.

{$DOMAIN:mailer.freela.ge} {
  encode gzip zstd

  header -Server
  header X-Content-Type-Options "nosniff"
  header X-Frame-Options "DENY"
  header Referrer-Policy "strict-origin-when-cross-origin"

  reverse_proxy app:3000 {
    health_uri      /api/health
    health_interval 15s
    health_timeout  5s
    health_status   200
    fail_duration   30s
    lb_try_duration 5s
    lb_try_interval 250ms
    flush_interval  -1
  }
}
